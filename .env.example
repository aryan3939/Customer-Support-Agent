# ==============================================================================
# Customer Support Agent - Environment Configuration
# ==============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:  copy .env.example .env
# 2. Fill in your Supabase + LLM API keys
# 3. Keep .env private - NEVER commit it to git!
#
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE (Supabase - FREE: 500MB, pgvector built-in!)
# ------------------------------------------------------------------------------
# Get your connection string from: https://supabase.com/dashboard
#   → Project Settings → Database → Connection string → URI
#
# IMPORTANT: Replace [YOUR-PASSWORD] with your Supabase database password
# The format below uses asyncpg driver for async support
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Supabase API (for direct Supabase features if needed later)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------------------------------------------
# REDIS (Optional - local Docker, for caching)
# ------------------------------------------------------------------------------
# Start with: docker-compose up -d
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# LLM PROVIDER - Choose ONE (both are FREE!)
# ------------------------------------------------------------------------------
# OPTION 1: Google AI Studio (Recommended - 60 req/min FREE)
#   Get key: https://aistudio.google.com/apikey
#
# OPTION 2: Groq (30 req/min FREE)
#   Get key: https://console.groq.com/keys

LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key_here

# Uncomment below to use Groq instead:
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your_groq_api_key_here

# ------------------------------------------------------------------------------
# LLM SETTINGS
# ------------------------------------------------------------------------------
# Google models: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
# Groq models: llama-3.1-70b-versatile, mixtral-8x7b-32768
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3

# ------------------------------------------------------------------------------
# LANGSMITH (Tracing & Observability — FREE: 5K traces/month)
# ------------------------------------------------------------------------------
# Get key: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=customer-support-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ------------------------------------------------------------------------------
# EMBEDDINGS (Runs locally - FREE, no API needed!)
# ------------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ------------------------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------------------------
APP_NAME=Customer Support Agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
APP_HOST=0.0.0.0
APP_PORT=8000

# ------------------------------------------------------------------------------
# SECURITY (Change these in production!)
# ------------------------------------------------------------------------------
JWT_SECRET=change-this-in-production-use-32-chars-minimum
API_KEY_SALT=change-this-too-different-from-jwt-secret

# ------------------------------------------------------------------------------
# AI AGENT BEHAVIOR
# ------------------------------------------------------------------------------
ENABLE_AUTO_RESOLUTION=true
MAX_AUTO_ATTEMPTS=3
ESCALATION_CONFIDENCE_THRESHOLD=0.7
